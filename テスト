REM ============================================================
REM INSERT INTO の存在チェック
REM ============================================================
findstr /i “INSERT INTO” “%IMPORT_FILE%” >nul 2>&1
if %ERRORLEVEL%==1 (
echo. | tee -a “%LOG_FILE%”
echo [ERROR] SQLファイルに INSERT INTO が見つかりませんでした。 | tee -a “%LOG_FILE%”
echo         ファイルの内容を確認してください: %IMPORT_FILE% | tee -a “%LOG_FILE%”
echo [INFO] ログ: %LOG_FILE%
pause
exit /b 1
)

REM ============================================================
REM インポート実行確認
REM ============================================================
echo –––––––––––––––––––––––––––– | tee -a “%LOG_FILE%”
echo  以下の内容でインポートを実行します                      | tee -a “%LOG_FILE%”
echo  DB_HOST    : %DB_HOST%                                  | tee -a “%LOG_FILE%”
echo  DB_PORT    : %DB_PORT%                                  | tee -a “%LOG_FILE%”
echo  DB_USER    : %DB_USER%                                  | tee -a “%LOG_FILE%”
echo  DB_NAME    : %DB_NAME%                                  | tee -a “%LOG_FILE%”
echo  IMPORT_FILE: %IMPORT_FILE%                              | tee -a “%LOG_FILE%”
echo –––––––––––––––––––––––––––– | tee -a “%LOG_FILE%”
echo. | tee -a “%LOG_FILE%”
set /p EXEC_CONFIRM=“インポートを実行しますか？ (EXECUTE/NO): “
if not “!EXEC_CONFIRM!”==“EXECUTE” (
echo [INFO] 処理を中止しました。 | tee -a “%LOG_FILE%”
pause
exit /b 1
)
echo. | tee -a “%LOG_FILE%”

REM ============================================================
REM MySQLインポート実行
REM ============================================================
echo [INFO] インポート開始: %DATE% %TIME% | tee -a “%LOG_FILE%”
echo. | tee -a “%LOG_FILE%”

REM テーブルごとに start / end を表示
for /f “tokens=3 delims= “ %%T in (‘findstr /i “INSERT INTO” “%IMPORT_FILE%”’) do (
set TABLE=%%T
set TABLE=!TABLE:(=!
echo [INSERT] !TABLE! start | tee -a “%LOG_FILE%”
echo [INSERT] !TABLE! end | tee -a “%LOG_FILE%”
)

mysql -h %DB_HOST% -P %DB_PORT% -u %DB_USER% -p%DB_PASS% %DB_NAME% < %IMPORT_FILE% >> “%LOG_FILE%” 2>&1

if %ERRORLEVEL%==0 (
echo. | tee -a “%LOG_FILE%”
echo [INFO] インポートが完了しました！: %DATE% %TIME% | tee -a “%LOG_FILE%”
echo [INFO] ログ: %LOG_FILE% | tee -a “%LOG_FILE%”
echo.
pause
) else (
echo. | tee -a “%LOG_FILE%”
echo [ERROR] インポートに失敗しました。終了コード: %ERRORLEVEL% | tee -a “%LOG_FILE%”
echo [INFO] ログ: %LOG_FILE%
pause
exit /b %ERRORLEVEL%
)

endlocal
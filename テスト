@echo off
setlocal enabledelayedexpansion

REM ============================================================
REM ログファイル設定
REM ============================================================
set LOG_DIR=%~dp0logs
if not exist “%LOG_DIR%” mkdir “%LOG_DIR%”
set LOG_FILE=%LOG_DIR%\import_%DATE:~0,4%%DATE:~5,2%%DATE:~8,2%_%TIME:~0,2%%TIME:~3,2%%TIME:~6,2%.log
set LOG_FILE=%LOG_FILE: =0%

REM ============================================================
REM 起動時に eula の値を読み込み、即 false にリセット
REM ============================================================
set AGREEMENT_FILE=%~dp0eula_import.txt
set AGREED=false
if exist “!AGREEMENT_FILE!” (
for /f “tokens=1,2 delims==” %%A in (‘findstr /i “eula” “!AGREEMENT_FILE!”’) do (
if /i “%%B”==“true” set AGREED=true
)
powershell -Command “(Get-Content ‘!AGREEMENT_FILE!’) -replace ‘eula=true’, ‘eula=false’ | Set-Content ‘!AGREEMENT_FILE!’”
)

echo ======================================================== | tee “%LOG_FILE%”
echo  MySQL インポートツール                                  | tee -a “%LOG_FILE%”
echo ======================================================== | tee -a “%LOG_FILE%”
echo. | tee -a “%LOG_FILE%”

REM ============================================================
REM パラメータ入力（必須チェックあり）
REM ============================================================
:INPUT_DB_HOST
set /p DB_HOST=“DBホスト名を入力してください (例: localhost): “
if “!DB_HOST!”==”” ( echo [ERROR] DBホスト名は必須です。 & goto INPUT_DB_HOST )

:INPUT_DB_PORT
set /p DB_PORT=“DBポートを入力してください (例: 3306): “
if “!DB_PORT!”==”” ( echo [ERROR] DBポートは必須です。 & goto INPUT_DB_PORT )
echo !DB_PORT!| findstr /r “^[0-9]*$” >nul 2>&1
if not %ERRORLEVEL%==0 ( echo [ERROR] DBポートは数字で入力してください。 & goto INPUT_DB_PORT )

:INPUT_DB_USER
set /p DB_USER=“DBユーザー名を入力してください: “
if “!DB_USER!”==”” ( echo [ERROR] DBユーザー名は必須です。 & goto INPUT_DB_USER )

:INPUT_DB_NAME
set /p DB_NAME=“DB名を入力してください: “
if “!DB_NAME!”==”” ( echo [ERROR] DB名は必須です。 & goto INPUT_DB_NAME )

:INPUT_DB_PASS
set /p DB_PASS=“DBパスワードを入力してください: “
if “!DB_PASS!”==”” ( echo [ERROR] DBパスワードは必須です。 & goto INPUT_DB_PASS )

:INPUT_IMPORT_FILE
set /p IMPORT_FILE=“インポートするSQLファイルパスを入力してください (例: C:\data\import.sql): “
if “!IMPORT_FILE!”==”” ( echo [ERROR] SQLファイルパスは必須です。 & goto INPUT_IMPORT_FILE )
if not exist “!IMPORT_FILE!” ( echo [ERROR] ファイルが見つかりません: !IMPORT_FILE! & goto INPUT_IMPORT_FILE )

echo. | tee -a “%LOG_FILE%”
echo –––––––––––––––––––––––––––– | tee -a “%LOG_FILE%”
echo  入力内容の確認                                          | tee -a “%LOG_FILE%”
echo  DB_HOST    : %DB_HOST%                                  | tee -a “%LOG_FILE%”
echo  DB_PORT    : %DB_PORT%                                  | tee -a “%LOG_FILE%”
echo  DB_USER    : %DB_USER%                                  | tee -a “%LOG_FILE%”
echo  DB_NAME    : %DB_NAME%                                  | tee -a “%LOG_FILE%”
echo  IMPORT_FILE: %IMPORT_FILE%                              | tee -a “%LOG_FILE%”
echo –––––––––––––––––––––––––––– | tee -a “%LOG_FILE%”
echo. | tee -a “%LOG_FILE%”
echo –––––––––––––––––––––––––––– | tee -a “%LOG_FILE%”
echo. | tee -a “%LOG_FILE%”
echo [INFO] MySQL接続を確認しています… | tee -a “%LOG_FILE%”
echo [INFO]   接続先: %DB_HOST%:%DB_PORT% | tee -a “%LOG_FILE%”
echo [INFO]   ユーザー: %DB_USER% | tee -a “%LOG_FILE%”
echo [INFO]   DB名: %DB_NAME% | tee -a “%LOG_FILE%”
mysql -h %DB_HOST% -P %DB_PORT% -u %DB_USER% -p%DB_PASS% -e “SELECT 1;” %DB_NAME% >”%TEMP%\mysql_err.tmp” 2>&1

if not %ERRORLEVEL%==0 (
echo. | tee -a “%LOG_FILE%”
echo [ERROR] MySQLへの接続に失敗しました。 | tee -a “%LOG_FILE%”
echo. | tee -a “%LOG_FILE%”
echo [ERROR] 考えられる原因: | tee -a “%LOG_FILE%”
for /f “delims=” %%E in (%TEMP%\mysql_err.tmp) do (
echo         %%E | tee -a “%LOG_FILE%”
)
echo. | tee -a “%LOG_FILE%”
echo [HINT] 以下を確認してください: | tee -a “%LOG_FILE%”
echo         - DBホスト名・IPアドレスが正しいか | tee -a “%LOG_FILE%”
echo         - ポート番号が正しいか (デフォルト: 3306) | tee -a “%LOG_FILE%”
echo         - ユーザー名・パスワードが正しいか | tee -a “%LOG_FILE%”
echo         - DB名が存在するか | tee -a “%LOG_FILE%”
echo         - MySQLサーバーが起動しているか | tee -a “%LOG_FILE%”
echo         - ファイアウォールでポートが開放されているか | tee -a “%LOG_FILE%”
echo [INFO] ログ: %LOG_FILE%
pause
exit /b 1
)
echo [INFO] 接続確認OK: %DB_HOST%:%DB_PORT% / %DB_NAME% | tee -a “%LOG_FILE%”
echo. | tee -a “%LOG_FILE%”

REM ============================================================
REM 本番環境チェック（DB_HOST が localhost 以外 = 本番とみなす）
REM ============================================================
if /i not “%DB_HOST%”==“localhost” (
echo ======================================================== | tee -a “%LOG_FILE%”
echo  [警告] 本番環境への接続が検出されました               | tee -a “%LOG_FILE%”
echo  DB_HOST  : %DB_HOST%                                   | tee -a “%LOG_FILE%”
echo  対象DB   : %DB_NAME%                                   | tee -a “%LOG_FILE%”
echo  ファイル : %IMPORT_FILE%                               | tee -a “%LOG_FILE%”
echo ======================================================== | tee -a “%LOG_FILE%”
echo. | tee -a “%LOG_FILE%”

